{
  "hooks": {
    "SessionStart": [
      { "hooks": [{ "type": "command", "command": "node /home/luismorales/projects/fleet-deck/fleetdeck/scripts/fleet-sessionstart.mjs", "timeout": 15 }] }
    ],
    "UserPromptSubmit": [
      { "hooks": [{ "type": "http", "url": "http://127.0.0.1:4711/hook/UserPromptSubmit", "timeout": 3 }] }
    ],
    "PostToolUse": [
      { "matcher": "Edit|Write|MultiEdit|NotebookEdit|Bash", "hooks": [{ "type": "http", "url": "http://127.0.0.1:4711/hook/PostToolUse", "timeout": 3 }] }
    ],
    "PreToolUse": [
      { "matcher": "AskUserQuestion", "hooks": [{ "type": "http", "url": "http://127.0.0.1:4711/hook/AskUserQuestion", "timeout": 65 }] }
    ],
    "PermissionRequest": [
      { "hooks": [{ "type": "http", "url": "http://127.0.0.1:4711/hook/PermissionRequest", "timeout": 65 }] }
    ],
    "Elicitation": [
      { "hooks": [{ "type": "http", "url": "http://127.0.0.1:4711/hook/Elicitation", "timeout": 65 }] }
    ],
    "Notification": [
      { "hooks": [{ "type": "http", "url": "http://127.0.0.1:4711/hook/Notification", "timeout": 3, "async": true }] }
    ],
    "Stop": [
      { "hooks": [
        { "type": "http", "url": "http://127.0.0.1:4711/hook/Stop", "timeout": 5 },
        {
          "type": "command",
          "command": "node /home/luismorales/projects/fleet-deck/fleetdeck/scripts/fleet-watch.mjs",
          "asyncRewake": true,
          "rewakeMessage": "[FLEETDECK] Fleet board mail for you:",
          "rewakeSummary": "Fleet Deck: board mail delivered",
          "timeout": 7230
        }
      ] }
    ],
    "SessionEnd": [
      { "hooks": [{ "type": "http", "url": "http://127.0.0.1:4711/hook/SessionEnd", "timeout": 3, "async": true }] }
    ],
    "FileChanged": [
      { "hooks": [{ "type": "http", "url": "http://127.0.0.1:4711/hook/FileChanged", "timeout": 3, "async": true }] }
    ]
  }
}
